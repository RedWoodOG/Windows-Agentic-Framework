<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="A9NDesktop.Views.Panels.BuddyPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <TextBlock x:Name="EmptyState" Visibility="Visible"
                   Text="Your buddy will appear here.&#x0a;Start a conversation to generate your companion."
                   Foreground="{StaticResource AppTextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" FontSize="13" Opacity="0.7"/>

    <ScrollViewer x:Name="BuddyContent" Visibility="Collapsed">
        <StackPanel Spacing="8">
            <TextBlock Text="Buddy" Style="{StaticResource SectionTitleTextStyle}"/>

            <!-- ASCII Art -->
            <Border Style="{StaticResource InsetCardStyle}" Padding="12">
                <TextBlock x:Name="AsciiArtText" FontFamily="Cascadia Mono, Consolas" FontSize="10"
                           Foreground="{StaticResource AppAccentBrush}" TextAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <!-- Name + Species -->
            <StackPanel HorizontalAlignment="Center" Spacing="2">
                <TextBlock x:Name="BuddyNameText" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource AppAccentTextBrush}" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock x:Name="SpeciesText" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    <Border x:Name="RarityBadge" CornerRadius="4" Padding="6,2">
                        <TextBlock x:Name="RarityText" FontSize="10" Foreground="White"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Stats -->
            <StackPanel Spacing="4" Margin="0,8,0,0">
                <TextBlock Text="Stats" Style="{StaticResource LabelTextStyle}"/>
                <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                    <TextBlock Grid.Row="0" Text="INT" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    <ProgressBar Grid.Row="0" Grid.Column="1" x:Name="IntBar" Maximum="100" Foreground="{StaticResource AppAccentBrush}"/>
                    <TextBlock Grid.Row="1" Text="ENR" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    <ProgressBar Grid.Row="1" Grid.Column="1" x:Name="EnrBar" Maximum="100" Foreground="#49C27D"/>
                    <TextBlock Grid.Row="2" Text="CRE" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    <ProgressBar Grid.Row="2" Grid.Column="1" x:Name="CreBar" Maximum="100" Foreground="#A080D0"/>
                    <TextBlock Grid.Row="3" Text="FRN" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    <ProgressBar Grid.Row="3" Grid.Column="1" x:Name="FrnBar" Maximum="100" Foreground="#E0A060"/>
                </Grid>
            </StackPanel>

            <!-- Soul -->
            <StackPanel Margin="0,8,0,0">
                <TextBlock Text="Soul" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,4"/>
                <TextBlock x:Name="SoulText" FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
    </Grid>
</UserControl>
