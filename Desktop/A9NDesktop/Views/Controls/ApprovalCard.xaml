<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="A9NDesktop.Views.Controls.ApprovalCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border BorderBrush="#CC4444" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,4"
            Background="{StaticResource AppInsetBrush}">
        <StackPanel>
            <TextBlock Text="Shell Command Approval" FontWeight="SemiBold" FontSize="13"
                       Foreground="#FF8A65" Margin="0,0,0,6"/>
            <Border Background="{StaticResource AppWindowBackgroundBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                <TextBlock x:Name="CommandText" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                           Foreground="{StaticResource AppAccentBrush}" TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="AllowOnceBtn" Content="Allow Once" Click="AllowOnce_Click"
                        Background="#2D4A2D" Foreground="#88DD88" CornerRadius="6" Padding="12,6"/>
                <Button x:Name="AllowSessionBtn" Content="Allow Session" Click="AllowSession_Click"
                        Background="#2D3D4A" Foreground="#88BBDD" CornerRadius="6" Padding="12,6"/>
                <Button x:Name="AlwaysAllowBtn" Content="Always Allow" Click="AlwaysAllow_Click"
                        Background="#3D3D2D" Foreground="#DDDD88" CornerRadius="6" Padding="12,6"/>
                <Button x:Name="DenyBtn" Content="Deny" Click="Deny_Click"
                        Background="#4A2D2D" Foreground="#DD8888" CornerRadius="6" Padding="12,6"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
